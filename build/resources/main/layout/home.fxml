<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.control.*?>
<VBox
    spacing="10"
    fx:controller="com.libcat.controller.HomeController"
    alignment="CENTER"
    fillWidth="false"
    xmlns:fx="http://javafx.com/fxml">
    
    <Label
    	styleClass="title"
    	text="Hello!" />
    
    <TextField
    	promptText="Book name, writer or ID"
    	fx:id="input" />
    	
    <Button
    	onAction="#showResults"
    	text="Search Books"
    	fx:id="searchButton" />
    
</VBox>